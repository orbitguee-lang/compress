──────────────────────────────────────────────── */
(function initParticles() {
  const canvas = document.getElementById('particles-canvas');
  const ctx = canvas.getContext('2d');
  let W, H, particles = [];

  function resize() {
    W = canvas.width  = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
  }

  class Particle {
    constructor() { this.reset(true); }
    reset(init = false) {
      this.x = Math.random() * W;
      this.y = init ? Math.random() * H : H + 10;
      this.r = Math.random() * 1.6 + 0.4;
      this.vx = (Math.random() - 0.5) * 0.4;
      this.vy = -(Math.random() * 0.5 + 0.2);
      this.alpha = Math.random() * 0.6 + 0.15;
      // amber-to-orange hue spread
      const hue = Math.random() * 25 + 15; // 15–40 deg
      this.color = `hsla(${hue},100%,62%,${this.alpha})`;
    }
    update() {
      this.x += this.vx; this.y += this.vy;
      if (this.y < -10) this.reset();
    }
    draw() {
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
      ctx.fillStyle = this.color;
      ctx.fill();
    }
  }

  function init() {
    resize();
    particles = Array.from({ length: 100 }, () => new Particle());
    loop();
  }

  function loop() {
    ctx.clearRect(0, 0, W, H);
    particles.forEach(p => { p.update(); p.draw(); });
    requestAnimationFrame(loop);
  }

  window.addEventListener('resize', resize);
  // Wait for splash screen to be visible
  setTimeout(init, 50);
})();

/* ──────────────────────────────────────────────
   QUALITY SELECTION
──────────────────────────────────────────────── */
function selectQuality(q) {
  const q1080 = document.getElementById('q1080');
  const q720  = document.getElementById('q720');
  const check = document.getElementById('check-1080');
  const radio = document.getElementById('radio-720');

  if (q === 1080) {
    q1080.classList.add('selected');    q720.classList.remove('selected');
    check.style.display = '';           radio.style.background = '';
    radio.style.borderColor = 'rgba(241,236,232,0.25)';
  } else {
    q720.classList.add('selected');     q1080.classList.remove('selected');
    check.style.display = 'none';
    radio.style.background = 'var(--orange)';
    radio.style.borderColor = 'var(--orange)';
  }
}

/* ──────────────────────────────────────────────
   FILE SELECT
──────────────────────────────────────────────── */
function handleFileSelect(input) {
  const f = input.files[0];
  if (!f) return;
  document.getElementById('file-name').textContent = f.name;
  document.getElementById('file-size').textContent = (f.size / 1024 / 1024).toFixed(1) + ' MB';
  // Preview from object URL
  const url = URL.createObjectURL(f);
  document.getElementById('preview-img').src = url;
}

/* ──────────────────────────────────────────────
   START COMPRESSION → navigate to progress
──────────────────────────────────────────────── */
function startCompression() {
  goTo('screen-progress');
}

/* ──────────────────────────────────────────────
   PROGRESS SIMULATION
──────────────────────────────────────────────── */
let progressInterval = null;
function startProgressSim() {
  if (progressInterval) clearInterval(progressInterval);

  let pct = 0;
  const arc = document.getElementById('progress-arc');
  const arcGlow = document.getElementById('progress-arc-glow');
  const pctEl = document.getElementById('progress-pct');
  const statusEl = document.getElementById('status-text');
  const timeEl = document.getElementById('time-remain');
  const stepEl = document.getElementById('active-step-text');
  const log = document.getElementById('process-log');
  const circumference = 678.6;

  const steps = [
    { pct: 20, status: 'Menganalisis frame video...', step: 'Mendeteksi scene changes...' },
    { pct: 40, status: 'Menghitung bitrate optimal...', step: 'Menyesuaikan resolusi HD...' },
    { pct: 60, status: 'Mengoptimalkan bitrate...', step: 'Menerapkan codec H.265...' },
    { pct: 80, status: 'Mengompres audio track...', step: 'Menyinkronkan audio-video...' },
    { pct: 95, status: 'Finalisasi output file...', step: 'Menulis metadata...' },
    { pct: 100, status: 'Selesai! ✓', step: 'Verifikasi integritas file...' },
  ];
  let stepIdx = 0;

  progressInterval = setInterval(() => {
    pct = Math.min(pct + 1, 100);

    // Update arc
    const offset = circumference - (pct / 100) * circumference;
    arc.setAttribute('stroke-dashoffset', offset);
    arcGlow.setAttribute('stroke-dashoffset', offset);
    pctEl.textContent = pct + '%';

    // Update step labels
    if (stepIdx < steps.length && pct >= steps[stepIdx].pct) {
      statusEl.textContent = steps[stepIdx].status;
      stepEl.textContent = steps[stepIdx].step;

      // Mark completed steps green
      if (stepIdx > 0) {
        const done = document.createElement('div');
        done.style.cssText = 'display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem;opacity:0.5;';
        done.innerHTML = `<span class="material-symbols-outlined fill-icon" style="color:#22c55e;font-size:18px;font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24;">check_circle</span><span style="font-size:0.85rem;">${steps[stepIdx-1].step}</span>`;
        // Insert before active step row
        const active = document.getElementById('active-step');
        log.insertBefore(done, active);
      }
      stepIdx++;
    }

    // Countdown
    const remain = Math.max(0, Math.round((100 - pct) * 0.15));
    const mm = String(Math.floor(remain / 60)).padStart(2,'0');
    const ss = String(remain % 60).padStart(2,'0');
    timeEl.textContent = `Sisa waktu: ${mm}:${ss}`;

    if (pct >= 100) {
      clearInterval(progressInterval);
      progressInterval = null;
      setTimeout(() => goTo('screen-success'), 600);
    }
  }, 60);
}

/* ──────────────────────────────────────────────
   CONFETTI
──────────────────────────────────────────────── */
function spawnConfetti() {
  const container = document.getElementById('confetti-container');
  container.innerHTML = '';
  const colors = ['#ff6933','#fbbf24','#f97316','#ff4d6d','#fff','#fde68a'];
  for (let i = 0; i < 70; i++) {
    const piece = document.createElement('div');
    piece.className = 'confetti-piece';
    piece.style.cssText = `
      left: ${Math.random()*100}%;
      background: ${colors[Math.floor(Math.random()*colors.length)]};
      animation-delay: ${Math.random()*2.5}s;
      animation-duration: ${2.5 + Math.random()*2}s;
      width: ${4+Math.random()*8}px;
      height: ${4+Math.random()*8}px;
      border-radius: ${Math.random() > 0.5 ? '50%' : '2px'};
    `;
    container.appendChild(piece);
  }
  // Clean up after animation
  setTimeout(() => container.innerHTML = '', 6000);
}

/* ──────────────────────────────────────────────
   RESPONSIVE GRID BREAKPOINTS
──────────────────────────────────────────────── */
function applyResponsiveGrids() {
  const w = window.innerWidth;
  const uploadGrid = document.getElementById('upload-grid');
  const successGrid = document.getElementById('success-grid');

  if (uploadGrid) {
    uploadGrid.style.gridTemplateColumns = w >= 1024 ? '7fr 5fr' : '1fr';
  }
  if (successGrid) {
    successGrid.style.gridTemplateColumns = w >= 768 ? '1fr 1fr' : '1fr';
  }
}

window.addEventListener('resize', applyResponsiveGrids);
applyResponsiveGrids();
</script>
