<!DOCTYPE html>
<html class="dark" lang="id">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>WhatsApp Story HD — Kompresi Cerdas</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet"/>
<script>
  tailwind.config = {
    darkMode: "class",
    theme: {
      extend: {
        colors: {
          "primary": "#ff6933",
          "primary-hover": "#ff8559",
          "bg-dark": "#23140f",
          "bg-card": "#2d1a12",
        },
        fontFamily: { "display": ["Inter", "sans-serif"] },
        borderRadius: {
          "DEFAULT": "0.25rem", "lg": "0.5rem",
          "xl": "0.75rem", "2xl": "1rem", "3xl": "1.5rem", "full": "9999px"
        },
      },
    },
  }
</script>
<style>
  /* ── Global Reset & Base ───────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; }
  :root {
    --orange: #ff6933;
    --orange-glow: rgba(255, 105, 51, 0.35);
    --orange-soft: rgba(255, 105, 51, 0.08);
    --bg: #23140f;
    --card: #2d1a12;
    --text: #f1ece8;
    --muted: rgba(241,236,232,0.5);
  }
  html, body { margin:0; padding:0; background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; }
  body { min-height: 100svh; overflow-x: hidden; }
  .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; line-height: 1; }
  .fill-icon { font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24; }

  /* ── Screen Management ─────────────────────────────── */
  .screen { display: none; min-height: 100svh; width: 100%; position: absolute; top: 0; left: 0; flex-direction: column; opacity: 0; transition: opacity 0.45s cubic-bezier(.4,0,.2,1); pointer-events: none; }
  .screen.active { display: flex; opacity: 1; pointer-events: all; position: relative; }
  .screen.fade-in { animation: screenIn 0.45s cubic-bezier(.4,0,.2,1) forwards; }
  @keyframes screenIn { from { opacity:0; transform: translateY(12px); } to { opacity:1; transform: translateY(0); } }

  /* ── Shared Header ─────────────────────────────────── */
  .app-header { display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.5rem; border-bottom: 1px solid rgba(255,105,51,0.12); }
  @media (min-width: 1024px) { .app-header { padding: 1rem 5rem; } }
  .logo-mark { display: flex; align-items: center; gap: 0.625rem; }
  .logo-icon { width: 36px; height: 36px; background: linear-gradient(135deg, #f59e0b, var(--orange)); border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 14px rgba(255,105,51,0.35); }
  .logo-icon .material-symbols-outlined { color: #fff; font-size: 20px; }
  .logo-text { font-weight: 800; font-size: 1.05rem; letter-spacing: -0.01em; color: var(--text); }

  /* ── Glow utilities ────────────────────────────────── */
  .glow { box-shadow: 0 0 24px var(--orange-glow), 0 0 48px rgba(255,105,51,0.15); }
  .glow-sm { box-shadow: 0 0 12px rgba(255,105,51,0.3); }
  .glow-xl { box-shadow: 0 0 40px rgba(255,105,51,0.4), 0 0 80px rgba(255,105,51,0.2); }
  .text-orange { color: var(--orange); }
  .bg-orange { background: var(--orange); }
  .border-orange { border-color: var(--orange); }

  /* ── Buttons ───────────────────────────────────────── */
  .btn-primary {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
    background: var(--orange); color: #fff; font-weight: 700; font-size: 1rem;
    border: none; border-radius: 14px; cursor: pointer; padding: 0 1.75rem; height: 56px;
    box-shadow: 0 0 20px rgba(255,105,51,0.35), 0 4px 16px rgba(255,105,51,0.25);
    transition: transform 0.18s ease, box-shadow 0.18s ease, opacity 0.18s ease;
    position: relative; overflow: hidden;
  }
  .btn-primary::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(255,255,255,0.12) 0%, transparent 60%);
    pointer-events: none;
  }
  .btn-primary:hover { transform: scale(1.025); box-shadow: 0 0 32px rgba(255,105,51,0.5), 0 6px 20px rgba(255,105,51,0.3); }
  .btn-primary:active { transform: scale(0.97); }
  .btn-outline {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
    background: transparent; color: var(--orange); font-weight: 700; font-size: 0.9rem;
    border: 2px solid var(--orange); border-radius: 14px; cursor: pointer;
    padding: 0 1.5rem; height: 48px;
    transition: background 0.18s, color 0.18s, transform 0.18s;
  }
  .btn-outline:hover { background: var(--orange); color: #fff; }
  .btn-outline:active { transform: scale(0.97); }
  .btn-ghost {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
    background: transparent; color: var(--orange); font-weight: 700;
    border: 1.5px solid rgba(255,105,51,0.3); border-radius: 14px; cursor: pointer;
    padding: 0 1.5rem; height: 48px; transition: background 0.18s, border-color 0.18s, transform 0.18s;
  }
  .btn-ghost:hover { background: rgba(255,105,51,0.08); border-color: var(--orange); }
  .btn-ghost:active { transform: scale(0.97); }

  /* ── Particles canvas ──────────────────────────────── */
  #particles-canvas { position: absolute; inset: 0; pointer-events: none; z-index: 0; }

  /* ────────────────────────────────────────────────────
     SCREEN 1 — SPLASH
  ──────────────────────────────────────────────────── */
  #screen-splash { background: var(--bg); overflow: hidden; justify-content: space-between; }
  #screen-splash .blob1 { position: absolute; top: -8%; left: -8%; width: 42%; height: 42%; background: rgba(255,105,51,0.12); border-radius: 50%; filter: blur(100px); pointer-events: none; }
  #screen-splash .blob2 { position: absolute; bottom: -10%; right: -6%; width: 55%; height: 55%; background: rgba(255,105,51,0.18); border-radius: 50%; filter: blur(140px); pointer-events: none; }
  .hero-icon-shell {
    width: 148px; height: 148px; border-radius: 36px;
    background: linear-gradient(135deg, #f59e0b 0%, #ff6933 60%, #ff4500 100%);
    padding: 3px; box-shadow: 0 0 0 1px rgba(255,105,51,0.2);
    position: relative;
  }
  @media (min-width: 768px) { .hero-icon-shell { width: 200px; height: 200px; border-radius: 48px; } }
  .hero-icon-inner {
    width: 100%; height: 100%; border-radius: calc(36px - 3px);
    background: #1a0d08; display: flex; align-items: center; justify-content: center;
  }
  @media (min-width: 768px) { .hero-icon-inner { border-radius: calc(48px - 3px); } }
  .hero-icon-inner .material-symbols-outlined {
    font-size: 64px;
    background: linear-gradient(135deg, #fbbf24, #ff6933);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  @media (min-width: 768px) { .hero-icon-inner .material-symbols-outlined { font-size: 96px; } }
  .hero-glow { position: absolute; inset: -20px; background: rgba(255,105,51,0.18); border-radius: 50%; filter: blur(40px); z-index: -1; }
  /* entrance animations */
  .anim-icon { animation: popIn 0.6s cubic-bezier(.34,1.56,.64,1) 0.1s both; }
  .anim-h1a  { animation: slideUp 0.55s cubic-bezier(.4,0,.2,1) 0.3s both; }
  .anim-h1b  { animation: slideUp 0.55s cubic-bezier(.4,0,.2,1) 0.42s both; }
  .anim-sub  { animation: slideUp 0.55s cubic-bezier(.4,0,.2,1) 0.54s both; }
  .anim-cta  { animation: fadeScaleIn 0.5s cubic-bezier(.4,0,.2,1) 0.66s both; }
  @keyframes popIn { from { opacity:0; transform: scale(0.75); } to { opacity:1; transform: scale(1); } }
  @keyframes slideUp { from { opacity:0; transform: translateY(24px); } to { opacity:1; transform: translateY(0); } }
  @keyframes fadeScaleIn { from { opacity:0; transform: scale(0.94); } to { opacity:1; transform: scale(1); } }
  .splash-cta { width: 100%; max-width: 320px; height: 64px; font-size: 1.1rem; border-radius: 18px; }
  .splash-cta:hover .arrow-icon { transform: translateX(5px); }
  .arrow-icon { transition: transform 0.25s ease; display: inline-block; }

  /* ────────────────────────────────────────────────────
     SCREEN 2 — OFFLINE
  ──────────────────────────────────────────────────── */
  #screen-offline { background: var(--bg); }
  .robot-wrapper { width: 256px; height: 256px; border-radius: 50%; background: rgba(255,105,51,0.05); display: flex; align-items: center; justify-content: center; position: relative; }
  .robot-img { width: 192px; height: 192px; background-size: contain; background-repeat: no-repeat; background-position: center; transition: transform 0.4s ease; }
  .robot-wrapper:hover .robot-img { transform: scale(1.05); }

  /* ────────────────────────────────────────────────────
     SCREEN 3 — UPLOAD
  ──────────────────────────────────────────────────── */
  #screen-upload { background: var(--bg); }
  .dashed-zone {
    border-radius: 16px; min-height: 400px; position: relative; cursor: pointer;
    background: rgba(255,105,51,0.04);
    background-image: url("data:image/svg+xml,%3csvg width='100%25' height='100%25' xmlns='http://www.w3.org/2000/svg'%3e%3crect width='100%25' height='100%25' fill='none' rx='16' ry='16' stroke='%23ff6933' stroke-width='3.5' stroke-dasharray='14%2c14' stroke-dashoffset='0' stroke-linecap='square'/%3e%3c/svg%3e");
    transition: background 0.2s;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 3rem 2rem; text-align: center;
  }
  .dashed-zone:hover { background: rgba(255,105,51,0.08); }
  .dashed-zone.drag-over { background: rgba(255,105,51,0.14); }
  .upload-icon-shell { width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, var(--orange), #ff8c66); display: flex; align-items: center; justify-content: center; box-shadow: 0 0 30px rgba(255,105,51,0.35); position: relative; }
  .upload-icon-shell .material-symbols-outlined { font-size: 40px; color: #fff; }
  .quality-card { border-radius: 14px; padding: 1rem; display: flex; align-items: center; justify-content: space-between; cursor: pointer; border: 2px solid transparent; transition: border-color 0.2s, background 0.2s; background: rgba(255,105,51,0.04); }
  .quality-card.selected { border-color: var(--orange); background: rgba(255,105,51,0.08); }
  .quality-card:not(.selected) { border-color: rgba(255,105,51,0.15); }
  .quality-card:not(.selected):hover { border-color: rgba(255,105,51,0.4); }
  .toggle-track { width: 44px; height: 24px; background: rgba(255,105,51,0.2); border-radius: 12px; position: relative; cursor: pointer; transition: background 0.25s; }
  .toggle-track.on { background: var(--orange); }
  .toggle-thumb { position: absolute; top: 2px; left: 2px; width: 20px; height: 20px; background: #fff; border-radius: 50%; transition: transform 0.25s cubic-bezier(.4,0,.2,1); box-shadow: 0 1px 4px rgba(0,0,0,0.3); }
  .toggle-track.on .toggle-thumb { transform: translateX(20px); }

  /* ────────────────────────────────────────────────────
     SCREEN 4 — COMPRESSION PROGRESS
  ──────────────────────────────────────────────────── */
  #screen-progress { background: var(--bg); }
  .progress-ring-circle { transition: stroke-dashoffset 0.6s cubic-bezier(.4,0,.2,1); transform-origin: 50% 50%; transform: rotate(-90deg); }
  .status-pulse { animation: pulseFade 2s ease-in-out infinite; }
  @keyframes pulseFade { 0%,100% { opacity:1; } 50% { opacity:0.5; } }
  .spin-icon { animation: spin360 1.2s linear infinite; }
  @keyframes spin360 { to { transform: rotate(360deg); } }
  .bar-shimmer { background: linear-gradient(90deg, var(--orange) 0%, #ffa07a 50%, var(--orange) 100%); background-size: 200%; animation: shimmer 2s linear infinite; }
  @keyframes shimmer { from { background-position: -200% 0; } to { background-position: 200% 0; } }

  /* ────────────────────────────────────────────────────
     SCREEN 5 — SUCCESS
  ──────────────────────────────────────────────────── */
  #screen-success { background: var(--bg); }
  .confetti-ring { position: absolute; inset: -40px; border-radius: 50%; background: radial-gradient(circle, rgba(255,105,51,0.2) 0%, transparent 65%); pointer-events: none; }
  .stat-card { border-radius: 14px; padding: 1rem 1.25rem; display: flex; align-items: center; gap: 1rem; background: rgba(255,105,51,0.05); border: 1px solid rgba(255,105,51,0.12); }
  .stat-icon { width: 44px; height: 44px; border-radius: 10px; background: rgba(255,105,51,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .stat-icon .material-symbols-outlined { color: var(--orange); font-size: 22px; }
  /* confetti particles */
  .confetti-piece { position: absolute; width: 8px; height: 8px; border-radius: 2px; animation: confettiFall 3.5s ease-in forwards; }
  @keyframes confettiFall {
    0% { transform: translateY(-20px) rotate(0deg); opacity: 1; }
    100% { transform: translateY(calc(100vh + 40px)) rotate(720deg); opacity: 0; }
  }

  /* ── Scrollbar ─────────────────────────────────────── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(255,105,51,0.25); border-radius: 3px; }

  /* ── Navigation demo buttons (dev helper) ──────────── */
  #dev-nav { position: fixed; bottom: 20px; right: 20px; z-index: 9999; display: flex; gap: 8px; flex-wrap: wrap; justify-content: flex-end; max-width: 320px; }
  .dev-btn { font-size: 10px; padding: 4px 10px; background: rgba(35,20,15,0.9); border: 1px solid rgba(255,105,51,0.4); color: var(--orange); border-radius: 8px; cursor: pointer; font-family: monospace; backdrop-filter: blur(8px); }
  .dev-btn:hover { background: rgba(255,105,51,0.15); }
</style>
</head>
<body>

<!-- ══════════════════════════════════════════════
     SCREEN 1 — SPLASH / LANDING
═══════════════════════════════════════════════ -->
<section class="screen active fade-in" id="screen-splash">
  <!-- Animated canvas particles -->
  <canvas id="particles-canvas"></canvas>
  <!-- Ambient blobs -->
  <div class="blob1"></div>
  <div class="blob2"></div>

  <!-- Header -->
  <header class="app-header" style="position:relative;z-index:2;">
    <div class="logo-mark">
      <div class="logo-icon">
        <span class="material-symbols-outlined fill-icon">hd</span>
      </div>
      <span class="logo-text">WhatsApp Story HD</span>
    </div>
  </header>

  <!-- Hero -->
  <main style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:2rem 1.5rem;position:relative;z-index:2;">
    <!-- Icon -->
    <div class="anim-icon" style="position:relative;margin-bottom:2.5rem;">
      <div class="hero-glow"></div>
      <div class="hero-icon-shell glow">
        <div class="hero-icon-inner">
          <span class="material-symbols-outlined">photo_library</span>
        </div>
      </div>
    </div>

    <!-- Headlines -->
    <h1 style="font-size:clamp(2.25rem,6vw,4.5rem);font-weight:900;line-height:1.1;letter-spacing:-0.03em;margin:0 0 1.25rem;max-width:700px;">
      <span class="anim-h1a" style="display:block;color:var(--text);">Kompresi Cerdas,</span>
      <span class="anim-h1b" style="display:block;color:var(--orange);">Kualitas Maksimal</span>
    </h1>

    <!-- Subheadline -->
    <p class="anim-sub" style="font-size:clamp(1rem,2vw,1.2rem);color:rgba(255,105,51,0.65);max-width:560px;margin:0 0 3rem;font-weight:500;line-height:1.6;">
      Optimalkan status WhatsApp Anda tanpa kehilangan detail. Teknologi AI terbaru untuk video dan foto jernih.
    </p>

    <!-- CTA -->
    <div class="anim-cta">
      <button class="btn-primary splash-cta" onclick="goTo('screen-upload')">
        Mulai Sekarang
        <span class="material-symbols-outlined arrow-icon">arrow_forward</span>
      </button>
    </div>
  </main>

  <!-- Footer loading hint -->
  <footer style="position:relative;z-index:2;padding:2rem 1.5rem;display:flex;flex-direction:column;align-items:center;gap:1rem;">
    <p style="font-size:0.7rem;letter-spacing:0.22em;text-transform:uppercase;color:rgba(255,105,51,0.5);font-weight:600;">
      Menyiapkan Mesin Kompresi
    </p>
    <div style="height:40px;width:100%;background:linear-gradient(to top,rgba(255,105,51,0.15),transparent);border-radius:50%;filter:blur(20px);"></div>
  </footer>
</section>


<!-- ══════════════════════════════════════════════
     SCREEN 2 — OFFLINE STATE
═══════════════════════════════════════════════ -->
<section class="screen" id="screen-offline">
  <!-- Header -->
  <header class="app-header">
    <div class="logo-mark">
      <div class="logo-icon"><span class="material-symbols-outlined fill-icon">hd</span></div>
      <span class="logo-text">WhatsApp Story HD</span>
    </div>
    <!-- Wifi-off badge -->
    <div style="width:40px;height:40px;border-radius:50%;background:rgba(255,105,51,0.12);display:flex;align-items:center;justify-content:center;">
      <span class="material-symbols-outlined text-orange" style="font-size:20px;">wifi_off</span>
    </div>
  </header>

  <!-- Body -->
  <main style="flex:1;display:flex;align-items:center;justify-content:center;padding:3rem 1.5rem;">
    <div style="display:flex;flex-direction:column;align-items:center;text-align:center;max-width:420px;gap:0;">
      <!-- Robot illustration container -->
      <div class="robot-wrapper" style="margin-bottom:2rem;">
        <div class="robot-img" style="background-image:url('https://lh3.googleusercontent.com/aida-public/AB6AXuBfXpA7p28VFJuAtFxn07gJ9jVThEYFBhMN5dXUWeY15az-gkWLnxnYjTU4jXRJg_f-vx4IJPa9gLmKsoqUtFlYKimEvDqhKQB_uk2SiPx1RXzG85MC3BYwNaqhKnzbfMxVMogx9pEektWlly61BUFP6d02XajM_VDBpKq1M-NzV5CpcDUJKjT4yW29G3u3TLmw4583vtlOjrht0QOopDGrrjU2aG0sYsBZSiSTAWS4kKBgn7aMCPiyq8olcCyf-jOYbIAb8HL2WU0');"></div>
      </div>

      <h1 style="font-size:clamp(1.9rem,5vw,2.6rem);font-weight:800;margin:0 0 1rem;letter-spacing:-0.02em;">
        Ups! Koneksi Terputus
      </h1>
      <p style="color:rgba(241,236,232,0.55);line-height:1.7;margin:0 0 2.5rem;font-size:0.97rem;">
        Sepertinya Anda sedang offline. Periksa koneksi internet Anda untuk melanjutkan kompresi media dengan kualitas HD.
      </p>

      <!-- Retry button -->
      <button class="btn-primary" style="width:100%;max-width:280px;" onclick="goTo('screen-upload')"
        onmouseenter="this.querySelector('.refresh-icon').style.transform='rotate(180deg)'"
        onmouseleave="this.querySelector('.refresh-icon').style.transform='rotate(0deg)'">
        <span class="material-symbols-outlined refresh-icon" style="transition:transform 0.5s ease;">refresh</span>
        Coba Lagi
      </button>
    </div>
  </main>
</section>


<!-- ══════════════════════════════════════════════
     SCREEN 3 — UPLOAD INTERFACE
═══════════════════════════════════════════════ -->
<section class="screen" id="screen-upload" style="overflow-y:auto;">
  <!-- Header -->
  <header class="app-header" style="position:sticky;top:0;z-index:50;backdrop-filter:blur(12px);background:rgba(35,20,15,0.85);">
    <div class="logo-mark">
      <div class="logo-icon"><span class="material-symbols-outlined fill-icon">hd</span></div>
      <span class="logo-text">WhatsApp Story HD</span>
    </div>
    <div style="display:flex;flex-direction:column;align-items:flex-end;">
      <span style="font-weight:700;font-size:0.85rem;">Premium User</span>
      <span style="font-size:0.75rem;color:var(--orange);">Pro Status Active</span>
    </div>
  </header>

  <main style="flex:1;padding:2rem 1.5rem;max-width:1200px;margin:0 auto;width:100%;">
    <div style="display:grid;grid-template-columns:1fr;gap:2rem;" id="upload-grid">

      <!-- ── LEFT PANEL ─────────────────────────────── -->
      <div style="display:flex;flex-direction:column;gap:1.5rem;">
        <!-- Drag-drop zone -->
        <div class="dashed-zone" id="drop-zone"
          ondragover="event.preventDefault();this.classList.add('drag-over')"
          ondragleave="this.classList.remove('drag-over')"
          ondrop="event.preventDefault();this.classList.remove('drag-over')"
          onclick="document.getElementById('file-input').click()">
          <!-- Radial glow -->
          <div style="position:absolute;inset:0;background:radial-gradient(circle at 50% 50%,rgba(255,105,51,0.12) 0%,transparent 70%);pointer-events:none;border-radius:16px;"></div>
          <div style="position:relative;margin-bottom:1.5rem;">
            <div style="position:absolute;inset:-16px;background:rgba(255,105,51,0.2);border-radius:50%;filter:blur(24px);"></div>
            <div class="upload-icon-shell">
              <span class="material-symbols-outlined">cloud_upload</span>
            </div>
          </div>
          <h3 style="font-size:1.5rem;font-weight:700;margin:0 0 0.5rem;">Upload Video Story</h3>
          <p style="color:rgba(241,236,232,0.5);margin:0 0 1.5rem;font-size:0.92rem;">
            Tarik dan lepas video di sini atau klik untuk memilih file
          </p>
          <button class="btn-primary" style="height:44px;font-size:0.9rem;" onclick="event.stopPropagation()">
            Pilih Video
          </button>
          <input type="file" id="file-input" accept="video/*" style="display:none;" onchange="handleFileSelect(this)">
        </div>

        <!-- Alert / Warning -->
        <div style="background:rgba(255,105,51,0.07);border:1px solid rgba(255,105,51,0.25);border-radius:14px;padding:1.25rem 1.25rem;display:flex;align-items:flex-start;gap:1rem;">
          <span class="material-symbols-outlined text-orange" style="font-size:28px;flex-shrink:0;margin-top:2px;">warning</span>
          <div>
            <p style="font-weight:700;font-size:0.9rem;color:var(--orange);margin:0 0 0.25rem;">
              Batas Ukuran File: Minimum 13 MB — Maksimum 550 MB
